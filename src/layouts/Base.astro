---
import SEO from '../components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  jsonLD?: Record<string, unknown>;
}

const { title = "Dewang Gogte", description, jsonLD } = Astro.props;

const SITE_URL = 'https://dewanggogte.com';

// Per-page descriptions
const pageDescriptions: Record<string, string> = {
  '/': 'AI and automation consultant in Bangalore. I build agents, document pipelines, and internal tools that replace manual operational work.',
  '/games/': 'Free browser games — identify watches, guess insects, and more.',
  '/projects/': 'Projects by Dewang Gogte — voice AI agents, stock screeners, and other things I have built.',
  '/resume/': 'Resume of Dewang Gogte — AI and automation consultant, Bangalore.',
  '/blog/': 'Writing about AI agents, automation, and things I learn building them.',
};

const pathname = Astro.url.pathname;
const pageDescription = description || pageDescriptions[pathname] || pageDescriptions['/'];

// Homepage JSON-LD: WebSite + Person
const isHomepage = pathname === '/';
const homepageJsonLD = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Dewang Gogte',
      url: SITE_URL,
      description: pageDescriptions['/'],
      author: { '@id': `${SITE_URL}/#person` },
    },
    {
      '@type': 'Person',
      '@id': `${SITE_URL}/#person`,
      name: 'Dewang Gogte',
      url: SITE_URL,
      jobTitle: 'AI & Automation Consultant',
      description: 'AI and automation consultant in Bangalore. I build agents, document pipelines, and internal tools that replace manual operational work.',
      knowsAbout: [
        'AI Agents',
        'Voice AI',
        'Workflow Automation',
        'Document Processing',
        'Product Consulting',
      ],
      sameAs: [
        'https://linkedin.com/in/dewanggogte',
        'https://instagram.com/dewangraphy',
        'https://github.com/dewanggogte',
      ],
    },
  ],
};

const finalJsonLD = jsonLD || (isHomepage ? homepageJsonLD : undefined);
---

<!DOCTYPE html>
<html lang="en">
<head>
    <SEO
      title={title}
      description={pageDescription}
      type="website"
      jsonLD={finalJsonLD}
    />
</head>
<body>
    <div class="container">
        <main>
            <slot />
        </main>
    </div>
</body>
</html>

<style is:global>
    :root {
        --bg: #fdfcfb;
        --text: #2c2c2c;
        --text-light: #666;
        --accent: #b85a3b;
        --border: #e8e6e3;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Source Serif 4', Georgia, serif;
        background: var(--bg);
        color: var(--text);
        font-size: 18px;
        line-height: 1.7;
    }

    .container {
        max-width: 640px;
        margin: 0 auto;
        padding: 4rem 3.5rem;
    }

    a {
        color: var(--accent);
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }

    header {
        margin-bottom: 1rem;
    }

    h1 {
        font-size: 1.5rem;
        font-weight: 500;
        margin-bottom: 0.25rem;
    }

    .location {
        color: var(--text-light);
        font-size: 1rem;
    }

    .available {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: var(--text-light);
        margin-bottom: 2.5rem;
    }

    .available::before {
        content: '●';
        color: #4a9;
        font-size: 0.6rem;
    }

    .bio {
        margin-bottom: 2rem;
    }

    .bio p {
        margin-bottom: 1rem;
    }

    .bio p:last-child {
        margin-bottom: 0;
    }

    .links-section {
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
    }

    .footer-row {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        justify-content: center;
        gap: 2rem;
    }

    .footer-row > a {
        font-size: 0.85rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-light);
    }

    .footer-row > a:hover {
        color: var(--accent);
        text-decoration: none;
    }


    .elsewhere {
        display: inline-flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
    }

    .elsewhere-label {
        font-size: 0.85rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-light);
    }

    .elsewhere a {
        font-size: 0.7rem;
        color: var(--text-light);
    }

    .elsewhere a:hover {
        color: var(--accent);
        text-decoration: none;
    }

    .elsewhere a::before {
        content: '•';
        margin-right: 0.5rem;
        color: var(--text-light);
    }

    .elsewhere a.icon-link {
        display: inline-flex;
        align-items: center;
        margin-left: 0.5rem;
    }

    .elsewhere a.icon-link::before {
        content: none;
    }

    .elsewhere a.icon-link svg {
        width: 16px;
        height: 16px;
    }

    @media (max-width: 480px) {
        .container {
            padding: 2rem 1.25rem;
        }
    }
</style>
