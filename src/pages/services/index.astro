---
// src/pages/services/index.astro
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import CTAButton from '../../components/CTAButton.astro';
import { PAYPAL_LINK, CALENDLY_CALL_URL, AUDIT_PRICE_USD } from '../../config/audit';
---

<Base title="Services — Dewang Gogte">
  <header>
    <h1>Services</h1>
    <p class="lead">
      I'm an AI and automation engineer based in Bangalore.
    </p>
  </header>

  <section class="bio">

    <p>
      I work with businesses that have a lot of repetitive operational work
      sitting on their team's plate and I either audit it, automate it, or
      embed in the team to do both.
    </p>

    <div class="cta-row">
      <CTAButton
        label={`Book an audit ($${AUDIT_PRICE_USD})`}
        href={PAYPAL_LINK}
        variant="primary"
        external
      />
      <CTAButton
        label="Schedule a call"
        href={CALENDLY_CALL_URL}
        variant="secondary"
        external
      />
    </div>

    <h2>What I help with</h2>
    <div class="card-grid">
      <div class="card">
        <h3>AI agents</h3>
        <p class="card-desc">LLM agents that take over repetitive operational work.</p>
      </div>
      <div class="card">
        <h3>Workflow automation</h3>
        <p class="card-desc">Pull data from multiple sources, collate, act.</p>
        <p class="card-detail">e.g. inbox triage, invoice chasing, lead enrichment.</p>
      </div>
      <div class="card">
        <h3>Document processing</h3>
        <p class="card-desc">Extract structured data from documents.</p>
        <p class="card-detail">e.g. PDFs, invoices, contracts.</p>
      </div>
      <div class="card">
        <h3>Voice pipelines</h3>
        <p class="card-desc">Voice agents for high-volume, low-complexity calls.</p>
        <p class="card-detail">e.g. price checks, appointment booking, follow-ups.</p>
        <p class="card-link">
          <a href="/services/case-studies/callkaro/">CallKaro case study &rarr;</a>
        </p>
      </div>
      <div class="card">
        <h3>Internal tooling</h3>
        <p class="card-desc">Web apps, dashboards, and CLI tools that replace spreadsheets.</p>
      </div>
      <div class="card">
        <h3>Fractional ops</h3>
        <p class="card-desc">I own your team's automation roadmap from inside Slack.</p>
        <p class="card-detail">For founders or COOs who need senior ops output without the hire.</p>
      </div>
    </div>

    <h2>Case studies</h2>
    <div class="case-grid">
      <a href="/services/case-studies/callkaro/" class="case-link">
        <strong>CallKaro</strong>
        <span class="case-desc">Voice AI for Hindi price checks</span>
        <span class="case-detail">Voice agent that calls local Indian stores in Hindi/Hinglish for retail price intelligence. Sub-2-second turn latency, 214 automated tests.</span>
        <span class="case-cta">Read case study &rarr;</span>
      </a>
      <a href="/services/case-studies/beacon/" class="case-link">
        <strong>Beacon</strong>
        <span class="case-desc">Autonomous equity research at scale</span>
        <span class="case-detail">All 5,300+ listed Indian companies scored on 21 metrics, then re-analyzed by a 4-agent LLM pipeline. End-to-end pipeline runs in under an hour.</span>
        <span class="case-cta">Read case study &rarr;</span>
      </a>
    </div>

    <h2>Types of engagements</h2>
    <div class="engagement-list">
      <details>
        <summary><strong>AI Operations Audit</strong></summary>
        <p>
          A week-long review of your team's work that finds 20+ hours worth of manual work 
          that AI can do faster and cheaper. If I can't find at least 20 hours a week of 
          automatable work, you get a full refund.
        </p>
        <p><a href="/audit/">More details on the audit page &rarr;</a></p>
      </details>
      <details>
        <summary><strong>Implementation projects</strong></summary>
        <p>
          Fixed-scope build for one or two of the wins identified in an audit
          (or that you've already mapped). Typically 2–6 weeks. You get a
          working system handed over with documentation.
        </p>
      </details>
      <details>
        <summary><strong>Monthly retainer</strong></summary>
        <p>
          Ongoing automation work for teams with a continuous backlog of
          repetitive processes. Fixed monthly hours, prioritized together.
          Best after we've shipped the first project.
        </p>
      </details>
      <details>
        <summary><strong>Fractional AI operations</strong></summary>
        <p>
          I sit in your team's Slack and own the automation roadmap, reporting
          directly to the founder or COO. Best suited for companies that need
          the output of a senior operator without the long-term commitment of
          hiring one.
        </p>
      </details>
    </div>

    <h2>How to start</h2>
    <p>
      You can directly book the AI Operations Audit below.
      For the other longer term engagements please schedule a short call.
    </p>

    <div class="cta-row">
      <CTAButton
        label={`Book an audit ($${AUDIT_PRICE_USD})`}
        href={PAYPAL_LINK}
        variant="primary"
        external
      />
      <CTAButton
        label="Schedule a call"
        href={CALENDLY_CALL_URL}
        variant="secondary"
        external
      />
    </div>
  </section>

  <Footer links={[
    { label: "Audit", href: "/audit/" },
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog/" },
    { label: "Projects", href: "/projects/" }
  ]} />
</Base>

<style>
  .lead {
    font-size: 1.15rem;
    color: var(--text-light);
    margin-top: 0.25rem;
    margin-bottom: 0;
    line-height: 1.5;
  }

  .cta-row {
    margin: 1.5rem 0 0.5rem;
  }

  .bio h2 {
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    column-gap: 2.75rem;
    row-gap: 0.25rem;
    margin: 0.5rem 0 1rem;
    align-items: start;
  }

  .card {
    padding: 0.9rem 0 0.8rem;
    border-top: 1px solid var(--border);
  }

  .card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
    line-height: 1.3;
    color: var(--text);
  }

  .card .card-desc {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.45;
    margin: 0;
  }

  .card .card-detail {
    font-size: 0.85rem;
    color: var(--text-light);
    font-style: italic;
    line-height: 1.45;
    margin: 0.35rem 0 0;
  }

  .card .card-link {
    margin: 0.5rem 0 0;
    font-size: 0.82rem;
  }

  .engagement-list {
    border-top: 1px solid var(--border);
    margin-bottom: 1rem;
  }

  .engagement-list details {
    border-bottom: 1px solid var(--border);
    padding: 0.7rem 0;
  }

  .engagement-list summary {
    cursor: pointer;
    list-style: none;
    padding-right: 1.5rem;
    position: relative;
    font-weight: 500;
  }

  .engagement-list summary::-webkit-details-marker {
    display: none;
  }

  .engagement-list summary::after {
    content: 'Details +';
    position: absolute;
    right: 0;
    top: 0;
    color: var(--text-light);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .engagement-list details[open] summary::after {
    content: 'Close −';
  }

  .engagement-list details.featured summary strong {
    color: var(--accent);
  }

  .engagement-list details p {
    margin-top: 0.6rem;
    margin-bottom: 0;
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .engagement-list details p + p {
    margin-top: 0.5rem;
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin: 0.5rem 0 1rem;
  }

  .case-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.1rem 0.95rem;
    background: #fff;
    color: var(--text);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .case-link:hover {
    border-color: var(--accent);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .case-link strong {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }

  .case-desc {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.45;
  }

  .case-detail {
    font-size: 0.85rem;
    color: var(--text-light);
    line-height: 1.55;
  }

  .case-cta {
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
  }
</style>

