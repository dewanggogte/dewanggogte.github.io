---
// src/pages/audit/index.astro
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import CTAButton from '../../components/CTAButton.astro';
import { PAYPAL_LINK, CALENDLY_CALL_URL, AUDIT_PRICE_USD } from '../../config/audit';

// JSON-LD for the audit service
const auditJsonLD = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI Operations Audit',
  provider: {
    '@type': 'Person',
    name: 'Dewang Gogte',
    url: 'https://dewanggogte.com',
  },
  areaServed: 'Worldwide',
  description:
    'A fixed-price audit that finds 20+ hours a week of work a small-to-mid-sized business can automate with AI. Guaranteed or free.',
  offers: {
    '@type': 'Offer',
    price: String(AUDIT_PRICE_USD),
    priceCurrency: 'USD',
  },
};
---

<Base title="AI Operations Audit — $250" jsonLD={auditJsonLD}>
  <header>
    <h1>AI Operations Audit</h1>
  </header>

  <section class="bio">

    <div class="value-callout">
      <p>
        I'll find 20+ hours a week of work your team is doing manually that AI
        can handle faster and cheaper. You will get an action-ready,
        prioritized list.
      </p>
      <p class="guarantee">
        <strong>If I can't find at least 20 hours a week of automatable
        work, you'll get a full refund.</strong>
      </p>
    </div>

    <p>
      Every business has high-volume repetitive digital processes, that the
      team performs manually. Things like switching through tens of portals to
      fetch data, sending messages or calls, or downloading and uploading
      reports from sheets.
    </p>

    <div class="cta-row">
      <CTAButton
        label={`Book an audit ($${AUDIT_PRICE_USD})`}
        href={PAYPAL_LINK}
        variant="primary"
        external
      />
      <CTAButton
        label="Schedule a call"
        href={CALENDLY_CALL_URL}
        variant="secondary"
        external
      />
    </div>

    <h2>What you get</h2>
    <div class="card-grid">
      <div class="card">
        <h3>Detailed report</h3>
        <p>
          Every repetitive process mapped, what's automatable, time and dollar
          savings, a phase 1/2/3 roadmap.
        </p>
      </div>
      <div class="card">
        <h3>Scoped proposals</h3>
        <p>For the 3 biggest wins.</p>
      </div>
      <div class="card">
        <h3>Review call</h3>
        <p>30-min review call post the audit.</p>
      </div>
    </div>

    <h2>How it works</h2>
    <ol class="step-grid">
      <li>
        <span class="step-num">1</span>
        <div>
          <h3>Pay + intake form</h3>
          <p>15-min intake form after payment.</p>
        </div>
      </li>
      <li>
        <span class="step-num">2</span>
        <div>
          <h3>Record Looms</h3>
          <p>2–3 short videos of the repetitive work.</p>
        </div>
      </li>
      <li>
        <span class="step-num">3</span>
        <div>
          <h3>Understanding call</h3>
          <p>30 minutes so I get the picture right.</p>
        </div>
      </li>
      <li>
        <span class="step-num">4</span>
        <div>
          <h3>Get the report</h3>
          <p>Detailed report in 5–7 business days.</p>
        </div>
      </li>
    </ol>

    <h2>FAQ</h2>
    <details>
      <summary>What tech do you actually build with?</summary>
      <p>
        I build with Python, TypeScript and other required tools like
        Retool, n8n, custom scripts, browser automation, direct APIs, etc. I
        pick tools that are easy to maintain, so as to need minimal maintenance from your team.
      </p>
    </details>
    <details>
      <summary>Do you sign NDAs?</summary>
      <p>Yes, happy to sign one if needed.</p>
    </details>
    <details>
      <summary>What happens after the audit?</summary>
      <p>
        If you want to hire me to build the top items, we can scope and price them.
        If not, we end the engagement. The report is always yours to keep and action.
      </p>
    </details>
    <details>
      <summary>What happens if the audit does not find anything?</summary>
      <p>
        If the audit does not find 20+ person-hours of weekly work saved, I will offer you a full refund.
      </p>
    </details>
    <details>
      <summary>What if my team cannot record Looms?</summary>
      <p>
        We can schedule a 30-min understanding call where someone from your team
        walks through the workflows over screen-share.
      </p>
    </details>
    <details>
      <summary>Wire transfer instead of card?</summary>
      <p>
        Happy to send a Business invoice. Email <a href="mailto:hello@dewanggogte.com">hello@dewanggogte.com</a> and
        I'll send it to you instead of the PayPal link.
      </p>
    </details>
    <details>
      <summary>Who's behind this?</summary>
      <p>
        I am Dewang Gogte, ex-American Express, Drip
        Capital.
      </br>Find more about<a href="/"> me</a> and my <a href="/projects/">projects</a>.
      </p>
    </details>
    <details>
      <summary>Have questions before booking a call?</summary>
      <p>
        Email <a href="mailto:hello@dewanggogte.com">hello@dewanggogte.com</a>. I usually reply within a day.
      </p>
    </details>

    <div class="cta-row final-cta">
      <CTAButton
        label={`Start the audit`}
        href={PAYPAL_LINK}
        variant="primary"
        external
      />
      <CTAButton
        label="Or book a short call"
        href={CALENDLY_CALL_URL}
        variant="secondary"
        external
      />
    </div>

  </section>

  <Footer links={[
    { label: "Services", href: "/services/" },
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog/" }
  ]} />
</Base>

<style>
  .value-callout {
    border-left: 3px solid var(--accent);
    background: #fff;
    padding: 1rem 1.25rem;
    margin: 0.5rem 0 1.5rem;
    border-radius: 0 4px 4px 0;
  }

  .value-callout p {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .value-callout p.guarantee {
    margin: 0;
    font-size: 1rem;
    color: var(--text);
  }

  .cta-row {
    margin: 1.5rem 0 2.5rem;
  }

  .bio h2 {
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.1rem;
    background: #fff;
  }

  .card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    line-height: 1.3;
  }

  .card p {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.55;
    margin: 0;
  }

  .step-grid {
    list-style: none;
    padding-left: 0;
    margin: 0 0 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .step-grid li {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.1rem;
    background: #fff;
    display: flex;
    gap: 0.8rem;
    margin: 0;
  }

  .step-grid .step-num {
    flex-shrink: 0;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--accent);
    line-height: 1;
  }

  .step-grid h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
    line-height: 1.3;
  }

  .step-grid p {
    font-size: 0.92rem;
    color: var(--text-light);
    line-height: 1.5;
    margin: 0;
  }

  .bio details {
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 0;
  }

  .bio details summary {
    cursor: pointer;
    font-weight: 500;
    list-style: none;
    padding-right: 1.5rem;
    position: relative;
  }

  .bio details summary::-webkit-details-marker {
    display: none;
  }

  .bio details summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    color: var(--text-light);
    font-weight: 400;
  }

  .bio details[open] summary::after {
    content: '−';
  }

  .bio details p {
    margin-top: 0.5rem;
    margin-bottom: 0;
    color: var(--text-light);
  }

  .final-cta {
    margin-top: 2.5rem;
  }
</style>
